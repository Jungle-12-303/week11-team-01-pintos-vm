{
  "name": "symbol-diff-console",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -s first \"node --import tsx src/server/index.ts\" \"vite --host 127.0.0.1 --port 5173\"",
    "dev:e2e": "SYMBOL_DIFF_API_PORT=5174 concurrently -k -s first \"node --import tsx src/server/index.ts\" \"vite --host 127.0.0.1 --port 5173\"",
    "start": "node --import tsx src/server/index.ts",
    "compare": "node --import tsx src/cli/compare.ts",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "build": "tsc --noEmit && vite build"
  },
  "dependencies": {
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/merge": "^6.12.1",
    "@codemirror/view": "^6.43.0",
    "codemirror": "^6.0.2",
    "express": "^5.2.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tree-sitter": "^0.21.1",
    "tree-sitter-c": "^0.21.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.2.1",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  }
}
