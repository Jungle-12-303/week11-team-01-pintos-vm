{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Pintos Debug",
            "type": "cppdbg",
            "request": "launch",
            "program": "/workspaces/week11-team-01-pintos-vm/pintos/vm/build/kernel.o",
            "cwd": "/workspaces/week11-team-01-pintos-vm/pintos/vm/build",
            "miDebuggerServerAddress": "localhost:1234",
            "miDebuggerPath": "/usr/bin/gdb",
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}
